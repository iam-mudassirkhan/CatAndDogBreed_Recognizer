<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".BreedDeteilsActivity">

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:src="@drawable/ic_back_arrow"
        android:layout_marginTop="@dimen/_10sdp"
        android:layout_marginStart="@dimen/_10sdp"
        />

    <TextView
        android:id="@+id/catBreed_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dog's Breed"
        android:textColor="@color/secondry_dark_brown"
        android:textSize="@dimen/_20sdp"
        android:layout_marginTop="@dimen/_10sdp"
        android:fontFamily="@font/inter_extrabold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />

    <ImageView
        android:id="@+id/breed_img"
        android:layout_width="@dimen/_160sdp"
        android:layout_height="@dimen/_160sdp"
        android:layout_marginBottom="-50dp"
        android:scaleType="centerCrop"
        android:background="@drawable/imag_view_round_circle_background"
        app:layout_constraintStart_toStartOf="@id/scroll_View"
        app:layout_constraintEnd_toEndOf="@id/scroll_View"
        app:layout_constraintBottom_toTopOf="@id/scroll_View"
        />


    <ScrollView
        android:id="@+id/scroll_View"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintHeight_percent="0.67"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        >
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/design_View"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/desing_view_from_bottom"
            app:layout_constraintStart_toStartOf="@id/scroll_View"
            app:layout_constraintEnd_toEndOf="@id/scroll_View"
            app:layout_constraintBottom_toBottomOf="@id/scroll_View"
            >






            <TextView
                android:id="@+id/summerytxtView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_extrabold"
                android:text="Summary"
                android:translationZ="@dimen/_10sdp"
                android:layout_marginStart="@dimen/_30sdp"
                android:layout_marginTop="@dimen/_40sdp"
                android:textColor="@color/secondry_dark_brown"
                android:textSize="@dimen/_22sdp"
                app:layout_constraintStart_toStartOf="@+id/design_View"
                app:layout_constraintTop_toTopOf="@+id/design_View" />

            <TextView
                android:id="@+id/breedShortDescription"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Akita make devoted companions, embodying a perfect blend of strength and affection in one majestic canine package."
                android:textSize="@dimen/_12sdp"
                android:background="@drawable/text_view_design_for_breed_deteils_activity"
                android:layout_marginHorizontal="@dimen/_50sdp"
                android:paddingHorizontal="@dimen/_20sdp"
                android:translationZ="@dimen/_10sdp"
                android:paddingVertical="@dimen/_5sdp"
                android:fontFamily="@font/inter_bold"
                android:textColor="@color/white"
                android:layout_marginTop="@dimen/_20sdp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/summerytxtView"
                />

            <TextView
                android:id="@+id/detailsTxtView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter_extrabold"
                android:text="Details"
                android:translationZ="@dimen/_10sdp"
                android:layout_marginStart="@dimen/_30sdp"
                android:layout_marginTop="@dimen/_15sdp"
                android:textColor="@color/secondry_dark_brown"
                android:textSize="@dimen/_22sdp"
                app:layout_constraintStart_toStartOf="@+id/design_View"
                app:layout_constraintTop_toBottomOf="@id/breedShortDescription" />

            <TextView
                android:id="@+id/breedShortDescription02"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Akitas are renowned for their unique blend of characteristics"
                android:textSize="@dimen/_12sdp"
                android:background="@drawable/text_view_design_for_breed_deteils_activity"
                android:layout_marginHorizontal="@dimen/_50sdp"
                android:paddingHorizontal="@dimen/_20sdp"
                android:translationZ="@dimen/_10sdp"
                android:paddingVertical="@dimen/_5sdp"
                android:fontFamily="@font/inter_bold"
                android:textColor="@color/white"
                android:layout_marginTop="@dimen/_20sdp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/detailsTxtView"
                />

            <TextView
                android:id="@+id/breedShortDescription03"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Akitas are revered for their noble bearing, making them not only formidable protectors but also gentle and affectionate family members"
                android:textSize="@dimen/_12sdp"
                android:background="@drawable/text_view_design_for_breed_deteils_activity"
                android:layout_marginHorizontal="@dimen/_50sdp"
                android:paddingHorizontal="@dimen/_20sdp"
                android:translationZ="@dimen/_10sdp"
                android:paddingVertical="@dimen/_5sdp"
                android:fontFamily="@font/inter_bold"
                android:textColor="@color/white"
                android:layout_marginTop="@dimen/_20sdp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/breedShortDescription02"
                />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </ScrollView>




</androidx.constraintlayout.widget.ConstraintLayout>